# Runtime
NODE_ENV=development
ADMIN_AUTH_MODE=temporary
# Required when ADMIN_AUTH_MODE=database. Generate a separate random value of at least 32 characters.
# AUTH_KEY_PEPPER=
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Temporary single-administrator authentication.
# Phase 1B will replace this with database-backed users and revocable sessions.
# Configure all three values together. AUTH_SECRET should be at least 32 characters.
AUTH_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-unique-password

# One-time CLI bootstrap only. Set these immediately before running
# `npm run admin:bootstrap`, then remove them from the environment.
# BOOTSTRAP_ADMIN_EMAIL=owner@example.com
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-one-time-password
# ALLOW_ADDITIONAL_SUPER_ADMIN=false

# Optional payments. Configure both values together when Stripe is enabled.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
